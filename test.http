### Tes Order
POST http://localhost:3000/cteapi/v1/orders
Content-Type: application/json
x-api-key: app_bb7c9b319f31397f493074e5fad15151

{
  "orderNumber": "ORD-TES-001",
  "totalAmount": 10000,
  "totalCogs": 1000,
  "paymentMethod": "CASH",
  "metadata": {
    "customer": "Rizky",
    "discord_id": "12312345"
  },
  "items":[
    {
      "itemName": "Tes Item 1",
      "qty": 1,
      "price": 10000,
      "cogs": 1100,
      "subtotal": 10000,
      "metadata": { "game_id": "1234567 (1000)" }
    },
    {
      "itemName": "Tes Fee",
      "qty": 1,
      "price": 15000,
      "cogs": 5000,
      "subtotal": 15000
    }
  ]
}

